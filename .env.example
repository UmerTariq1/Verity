# ═══════════════════════════════════════════════════════════════════════════════
# Verity — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: postgresql://verity:verity@localhost:5432/verity
# Docker:    postgresql://verity:verity@db:5432/verity
DATABASE_URL=postgresql://verity:verity@db:5432/verity

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pinecone (only needed when VECTOR_STORE=pinecone) ─────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=verity
PINECONE_ENVIRONMENT=gcp-starter

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-me-with-a-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LangSmith (optional — set LANGCHAIN_TRACING_V2=false to disable) ──────────
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=verity

# ── Vector store ──────────────────────────────────────────────────────────────
# 'chroma' → local ChromaDB (default for dev)
# 'pinecone' → hosted Pinecone (production)
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db

# ── Chunking ──────────────────────────────────────────────────────────────────
# 'recursive' recommended for structured HR policy documents
# 'fixed' is a useful baseline for comparison experiments
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Netlify/GitHub Pages URL for production.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
